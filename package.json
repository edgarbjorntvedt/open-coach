{
  "name": "open-coach",
  "version": "0.1.0",
  "description": "Hands-free Norwegian AI coach using OpenAI Realtime API (GPT-4o)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "open-coach": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "tsx --env-file=.env src/index.ts"
  },
  "engines": {
    "node": ">=20.6"
  },
  "keywords": [
    "ai",
    "coach",
    "realtime",
    "openai",
    "norwegian"
  ],
  "author": "Edgar Bjørntvedt",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
