OPENAI_API_KEY=

# Path to a folder where your personal data is kept (themes.md, prep-next.md, sessions/).
# Defaults to a temp folder so the app starts up without setup. Point this at a
# persistent location of your choice — how you back up that folder is up to you.
OPEN_COACH_STORAGE=/tmp/open-coach-storage

# OpenAI Realtime model. Override to test other models (e.g. gpt-4o-mini-realtime-preview).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Session timeouts. Whichever fires first ends the session.
MAX_SESSION_MINUTES=30
INACTIVITY_TIMEOUT_SECONDS=120
