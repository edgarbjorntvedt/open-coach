OPENAI_API_KEY=

# Where personal data is stored (themes.md, prep-next.md, sessions/).
# Defaults to $HOME/.open-coach if unset. Override to point elsewhere.
# OPEN_COACH_STORAGE=/path/to/your/storage

# OpenAI Realtime model. Override to test other models (e.g. gpt-4o-mini-realtime-preview).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Session timeouts. Whichever fires first ends the session.
# Inactivity = no audio from either side (mic or coach) for this many seconds.
MAX_SESSION_MINUTES=30
INACTIVITY_TIMEOUT_SECONDS=120
