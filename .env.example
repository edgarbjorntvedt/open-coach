OPENAI_API_KEY=

# Where personal data is stored (themes.md, prep-next.md, sessions/).
# Defaults to $HOME/.open-coach if unset. Override to point elsewhere.
# OPEN_COACH_STORAGE=/path/to/your/storage

# Conversation language. Picks the language used for transcript labels and session-file headers.
# Supported out of the box: en (English), no (Norwegian).
# Default: en. Extend src/i18n.ts to add more.
OPEN_COACH_LANGUAGE=en

# Your name. Used in the system prompt (the coach addresses you by name) and
# as the label for your lines in the session transcript.
# Leave empty to fall back to a generic word in the chosen language.
OPEN_COACH_USER_NAME=Edgar

# OpenAI Realtime model. Override to test other models (e.g. gpt-4o-realtime-preview).
OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview

# Session timeouts. Whichever fires first ends the session.
# Inactivity = no audio from either side (mic or coach) for this many seconds.
MAX_SESSION_MINUTES=30
INACTIVITY_TIMEOUT_SECONDS=120
